post_install() {
    echo ":: linux-gaokun3 has been installed."
    echo "   Kernel image: /boot/vmlinuz-linux-gaokun3"
    echo "   Config: /boot/config-linux-gaokun3"
    echo ""
    echo ":: Remember to update your bootloader configuration."
}

post_upgrade() {
    post_install
}

pre_remove() {
    echo ":: Removing linux-gaokun3..."
}